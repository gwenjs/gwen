{
  "name": "gwen",
  "version": "0.0.0",
  "private": true,
  "description": "GWEN - Composable Web Game Engine",
  "license": "MPL-2.0",
  "author": "Jonathan Moutier <djo.moutier@gmail.com>",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gwenjs/gwen"
  },
  "scripts": {
    "prepare": "husky",
    "install:all": "pnpm install && rustup target add wasm32-unknown-unknown && pnpm build:wasm",
    "build": "pnpm build:wasm && pnpm build:ts",
    "build:ts": "pnpm --filter '@gwenjs/*' build",
    "build:wasm:tools": "./scripts/build-wasm-tools.sh",
    "build:wasm": "./scripts/build-wasm.sh",
    "build:cargo": "./scripts/clean-cargo.sh build",
    "build:cargo:debug": "./scripts/clean-cargo.sh build-debug",
    "dev": "concurrently \"./scripts/clean-cargo.sh watch\" \"pnpm -r dev\"",
    "test": "./scripts/clean-cargo.sh test && pnpm -r test",
    "test:ts": "pnpm --filter '@gwenjs/*' test",
    "test:cargo": "./scripts/clean-cargo.sh test",
    "bench": "cargo bench",
    "bench:ci": "pnpm --filter @gwenjs/core bench:ci && pnpm --filter @gwenjs/physics2d bench:ci",
    "bench:core:ci": "pnpm --filter @gwenjs/core bench:ci",
    "bench:physics:ci": "pnpm --filter @gwenjs/physics2d bench:ci",
    "clean": "./scripts/clean-cargo.sh clean && pnpm -r clean",
    "lint": "oxlint --config oxlint.json packages/",
    "lint:fix": "oxlint --config oxlint.json --fix packages/",
    "format": "oxfmt packages/",
    "format:check": "oxfmt --check packages/",
    "typecheck": "pnpm --filter '@gwenjs/*' exec tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "verdaccio:start": "verdaccio --config ./verdaccio.yaml",
    "verdaccio:publish": "./scripts/verdaccio-publish.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "concurrently": "^8.2.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4"
  }
}
