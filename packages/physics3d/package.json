{
  "name": "@gwenjs/physics3d",
  "version": "0.1.0",
  "description": "3D physics plugin foundation for GWEN — Rapier3D adapter surface",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@gwenjs/core": "workspace:*",
    "@gwenjs/kit": "workspace:*",
    "@gwenjs/vite": "workspace:*"
  },
  "devDependencies": {
    "hookable": "^6.0.1",
    "magic-string": "^0.30.21",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  }
}
