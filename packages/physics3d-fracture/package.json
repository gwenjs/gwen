{
  "name": "@gwenjs/physics3d-fracture",
  "version": "0.1.0",
  "description": "Voronoi mesh fracture — standalone WASM module for GWEN Physics 3D",
  "license": "MPL-2.0",
  "files": [
    "dist",
    "wasm"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./wasm": {
      "types": "./wasm/gwen_physics3d_fracture.d.ts",
      "import": "./wasm/gwen_physics3d_fracture.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./wasm": {
        "types": "./wasm/gwen_physics3d_fracture.d.ts",
        "import": "./wasm/gwen_physics3d_fracture.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.0"
  }
}
