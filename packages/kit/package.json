{
  "name": "@gwenjs/kit",
  "version": "0.2.0",
  "description": "GWEN plugin authoring kit — helpers for creating TS and WASM plugins",
  "keywords": [
    "game-engine",
    "gwen",
    "kit",
    "plugin",
    "wasm"
  ],
  "license": "MPL-2.0",
  "author": "Jonathan Moutier <djo.moutier@gmail.com>",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./src/plugin/index.ts",
      "import": "./src/plugin/index.ts"
    },
    "./module": {
      "types": "./src/module/index.ts",
      "import": "./src/module/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./plugin": {
        "types": "./dist/plugin/index.d.ts",
        "import": "./dist/index.js"
      },
      "./module": {
        "types": "./dist/module/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@gwenjs/core": "workspace:*",
    "@gwenjs/schema": "workspace:*"
  },
  "devDependencies": {
    "@gwenjs/app": "workspace:*",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "gwen": {
    "type": "kit"
  }
}
