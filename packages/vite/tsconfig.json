{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    // FIXME(type-safety): exactOptionalPropertyTypes disabled — tracked in specs/v2-fix/05-TYPE-SAFETY.md
    "exactOptionalPropertyTypes": false,
    // FIXME(type-safety): noUncheckedIndexedAccess disabled — tracked in specs/v2-fix/05-TYPE-SAFETY.md
    "noUncheckedIndexedAccess": false,
    "rootDir": "../.."
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.js", "src/**/*.d.ts"],
  "extends": "../../tsconfig.base.json",
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../kit"
    },
    {
      "path": "../physics2d"
    }
  ]
}
