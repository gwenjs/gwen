{
  "name": "@gwenjs/vite",
  "version": "0.1.0",
  "description": "Vite plugin for GWEN — WASM hot-reload, asset copying, manifest injection",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./transform": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gwenjs/kit": "workspace:*",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.123.0",
    "oxc-walker": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  }
}
